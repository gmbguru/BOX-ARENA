       <div class="flex items-center gap-2 text-green-400 font-semibold">
        <span>Book Now</span>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewbox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
        </svg>
       </div>
      </div><!-- Bowling Machine -->
      <div class="facility-card glass-card rounded-2xl p-6 border border-transparent transition-all duration-300 cursor-pointer" onclick="openWhatsApp('bowling')">
       <div class="w-16 h-16 bg-gradient-to-br from-orange-500 to-red-600 rounded-2xl flex items-center justify-center mb-6">
        <span class="text-3xl">🎯</span>
       </div>
       <h3 class="font-bebas text-2xl text-white mb-3">Bowling Machine</h3>
       <p class="text-gray-400 mb-4">Improve your batting skills with our advanced bowling machine, suitable for beginners and professional players.</p>
       <div class="flex items-center gap-2 text-green-400 font-semibold">
        <span>Book Now</span>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewbox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
        </svg>
       </div>
