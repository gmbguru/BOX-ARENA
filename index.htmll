       <img src="https://lh3.googleusercontent.com/p/AF1QipP4hpR6oRaZwIOezSpW2wA__ZYqmYcD2kv3qHw6=s1360-w1360-h1020-rw" alt="BOX ARENA Sports" loading="lazy" class="w-full h-48 sm:h-64 object-cover" onerror="console.error('Image failed to load:', this.src); this.style.background='linear-gradient(135deg, #22c55e 0%, #16a34a 100%)'; this.alt='Gallery Image';">
