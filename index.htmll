   </div><!-- Floating WhatsApp Button --> <button onclick="openWhatsApp('floating')" class="fixed bottom-6 right-6 z-50 whatsapp-btn w-16 h-16 rounded-full flex items-center justify-center shadow-2xl animate-pulse-glow transition-all hover:scale-110">
    <svg class="w-8 h-8" fill="currentColor" viewbox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z" />
    </svg></button>
  </div>
  <script>
    // Configuration
    const defaultConfig = {
      hero_title: 'BOX ARENA',
      hero_subtitle: 'Box Cricket, Football Turf & Bowling Machine in Sarita Vihar, Delhi',
      phone_number: '+91 92662 01271',
      address_text: 'SHANTI BHAWAN, Sarita Vihar District Park, 22/1, Sarita Vihar, New Delhi, Delhi 110076',
      primary_color: '#22c55e',
      secondary_color: '#0f172a',
      text_color: '#ffffff',
      accent_color: '#4ade80',
      surface_color: 'rgba(255, 255, 255, 0.05)'
    };

    // Gallery images
    const galleryImages = [
      'https://lh3.googleusercontent.com/p/AF1QipPC9xeW3Keel7caUpn1mXrJW-xYcffufCKEbiID=s1360-w1360-h1020-rw',
      'https://lh3.googleusercontent.com/gps-cs-s/AHVAwerNqUx_ciqR3Y2gDPuMJLuizkSNVPWf2RD4-fyyB_VKiqjRF8ZEqk3aulNLSSFVQTzckjy5Spclu_jRUvTzURju-CTy5tEOZZTbvuy90xJ5ruO53MlCn3-2Tg2LXa9BDeZ3rNDnN6bBGMk=s1360-w1360-h1020-rw',
      'https://lh3.googleusercontent.com/p/AF1QipP4hpR6oRaZwIOezSpW2wA__ZYqmYcD2kv3qHw6=s1360-w1360-h1020-rw',
      'https://lh3.googleusercontent.com/gps-cs-s/AHVAweo-vy1-hXGW8RgwLwQRHXn-yxYoqKhopedITlYHySsoeR3yWdwj70D3gkm5fZXGV6jOtYvrJcrcZBtOX0_1IZXpwZa-TZ_BU4Swi_R_sgd2ZqHTa9KrIMpWwXqx7-XeLflOglWMcVYeKT44=s1360-w1360-h1020-rw'
    ];
    
    let currentImageIndex = 0;

    // WhatsApp Lead Function with prefilled message
    function openWhatsApp(source) {
      const config = window.elementSdk ? window.elementSdk.config : defaultConfig;
      const phone = (config.phone_number || defaultConfig.phone_number).replace(/[^0-9]/g, '');
      
      const sourceMessages = {
        'nav': 'Hi! I found BOX ARENA online and would like to book a slot.',
        'mobile-nav': 'Hi! I found BOX ARENA online and would like to book a slot.',
        'hero-book': 'Hi! I am interested in booking a slot at BOX ARENA.',
        'box-cricket': 'Hi! I would like to book the Box Cricket Turf at BOX ARENA.',
        'football': 'Hi! I would like to book the Football Turf at BOX ARENA.',
        'bowling': 'Hi! I would like to book the Bowling Machine Practice at BOX ARENA.',
        'practice-nets': 'Hi! I would like to book the Open Practice Nets at BOX ARENA.',
        'tournaments': 'Hi! I would like to organize a Tournament/Group Match at BOX ARENA.',
        'corporate': 'Hi! I would like to book BOX ARENA for a Corporate/Birthday Event.',
        'gallery': 'Hi! I saw the gallery and would like to visit BOX ARENA.',
        'pricing-cricket': 'Hi! I am interested in booking the Box Cricket Turf. Please share available slots and pricing details.',
        'pricing-football': 'Hi! I am interested in booking the Football Turf. Please share available slots and pricing details.',
        'pricing-bowling': 'Hi! I am interested in the Bowling Machine Practice. Please share available slots and pricing details.',
        'pricing-nets': 'Hi! I am interested in the Practice Nets. Please share available slots and pricing details.',
        'pricing-inquiry': 'Hi! I would like to inquire about custom pricing packages and offers for groups/corporate events.',
        'location': 'Hi! I would like to book a slot at BOX ARENA, Sarita Vihar.',
        'cta-main': 'Hi! I am ready to book my game at BOX ARENA!',
        'footer': 'Hi! I would like to inquire about BOX ARENA.',
        'footer-about': 'Hi! I would like to know more about BOX ARENA.',
        'lightbox': 'Hi! I saw your facilities and would like to book a slot.',
        'floating': 'Hi! I would like to book a slot at BOX ARENA.'
      };

      const leadFormat = `
*--- BOX ARENA BOOKING INQUIRY ---*

${sourceMessages[source] || 'Hi! I would like to book a slot at BOX ARENA.'}

*Name:* [Please enter your name]
*Date:* [Preferred date]
*Time Slot:* [Preferred time]
*Activity:* [Cricket/Football/Bowling/Other]
*Number of Players:* [Number]

*Source:* Website - ${source}

Looking forward to your response!
      `.trim();

      const encodedMessage = encodeURIComponent(leadFormat);
      const whatsappUrl = `https://wa.me/${phone}?text=${encodedMessage}`;
      
      window.open(whatsappUrl, '_blank');
    }

    // Lightbox Functions
    function openLightbox(index) {
      currentImageIndex = index;
      const lightbox = document.getElementById('lightbox');
      const lightboxImg = document.getElementById('lightbox-img');
      lightboxImg.src = galleryImages[index];
      lightbox.classList.add('active');
      document.body.style.overflow = 'hidden';
    }

    function closeLightbox() {
      const lightbox = document.getElementById('lightbox');
      lightbox.classList.remove('active');
      document.body.style.overflow = '';
    }

    function navigateLightbox(direction) {
      currentImageIndex = (currentImageIndex + direction + galleryImages.length) % galleryImages.length;
      const lightboxImg = document.getElementById('lightbox-img');
      lightboxImg.src = galleryImages[currentImageIndex];
    }

    // Keyboard navigation for lightbox
    document.addEventListener('keydown', (e) => {
      const lightbox = document.getElementById('lightbox');
      if (lightbox.classList.contains('active')) {
        if (e.key === 'Escape') closeLightbox();
        if (e.key === 'ArrowLeft') navigateLightbox(-1);
        if (e.key === 'ArrowRight') navigateLightbox(1);
      }
    });

    // Close lightbox on background click
    document.getElementById('lightbox').addEventListener('click', (e) => {
      if (e.target.id === 'lightbox') {
        closeLightbox();
      }
    });

    // Element SDK Integration
    if (window.elementSdk) {
      window.elementSdk.init({
        defaultConfig,
        onConfigChange: async (config) => {
          // Update hero title
          const heroTitle = document.getElementById('hero-title');
          if (heroTitle) {
            const title = config.hero_title || defaultConfig.hero_title;
            const parts = title.split(' ');
            heroTitle.innerHTML = `<span class="text-white">${parts[0] || 'BOX'}</span><span class="text-gradient"> ${parts.slice(1).join(' ') || 'ARENA'}</span>`;
          }

          // Update nav title
          const navTitle = document.getElementById('nav-title');
          if (navTitle) {
            navTitle.textContent = config.hero_title || defaultConfig.hero_title;
          }

          // Update hero subtitle
          const heroSubtitle = document.getElementById('hero-subtitle');
          if (heroSubtitle) {
            heroSubtitle.textContent = config.hero_subtitle || defaultConfig.hero_subtitle;
          }

          // Update phone display
          const phoneDisplay = document.getElementById('phone-display');
          if (phoneDisplay) {
            phoneDisplay.innerHTML = `<span class="text-2xl">📞</span><span class="text-xl font-semibold">${config.phone_number || defaultConfig.phone_number}</span>`;
          }

          // Update footer phone display
          const footerPhone = document.getElementById('footer-phone');
          if (footerPhone) {
            footerPhone.textContent = config.phone_number || defaultConfig.phone_number;
          }

          // Update address display
          const addressDisplay = document.getElementById('address-display');
          if (addressDisplay) {
            const address = config.address_text || defaultConfig.address_text;
            addressDisplay.innerHTML = address.replace(/,/g, ',<br>');
          }
        },
        mapToCapabilities: (config) => ({
          recolorables: [
            {
              get: () => config.primary_color || defaultConfig.primary_color,
              set: (value) => {
                config.primary_color = value;
                window.elementSdk.setConfig({ primary_color: value });
              }
            },
            {
              get: () => config.secondary_color || defaultConfig.secondary_color,
              set: (value) => {
                config.secondary_color = value;
                window.elementSdk.setConfig({ secondary_color: value });
              }
            },
            {
              get: () => config.text_color || defaultConfig.text_color,
              set: (value) => {
                config.text_color = value;
                window.elementSdk.setConfig({ text_color: value });
              }
            }
          ],
          borderables: [],
          fontEditable: undefined,
          fontSizeable: undefined
        }),
        mapToEditPanelValues: (config) => new Map([
          ['hero_title', config.hero_title || defaultConfig.hero_title],
          ['hero_subtitle', config.hero_subtitle || defaultConfig.hero_subtitle],
          ['phone_number', config.phone_number || defaultConfig.phone_number],
          ['address_text', config.address_text || defaultConfig.address_text]
        ])
      });
    }

    // Scroll animations
    const observerOptions = {
      threshold: 0.1,
      rootMargin: '0px 0px -50px 0px'
    };

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('section-visible');
        }
      });
    }, observerOptions);

    document.querySelectorAll('section').forEach(section => {
      observer.observe(section);
    });
  </script>
